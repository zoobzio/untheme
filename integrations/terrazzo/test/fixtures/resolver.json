{
  "name": "Fixture",
  "version": "2025.10",
  "sets": {
    "core": {
      "sources": [{ "$ref": "./base.json" }]
    }
  },
  "modifiers": {
    "color": {
      "contexts": {
        "light": [{}],
        "dark": [
          {
            "color": {
              "$type": "color",
              "primary": {
                "default": { "$value": "{color.primary.50}" }
              },
              "surface": {
                "$value": {
                  "colorSpace": "srgb",
                  "components": [
                    0.06666666666666667, 0.06666666666666667,
                    0.06666666666666667
                  ],
                  "alpha": 1,
                  "hex": "#111111"
                }
              }
            }
          }
        ]
      },
      "default": "light"
    },
    "density": {
      "contexts": {
        "default": [{}],
        "compact": [
          {
            "size": {
              "$type": "dimension",
              "md": { "$value": { "value": 6, "unit": "px" } }
            }
          }
        ]
      },
      "default": "default"
    }
  },
  "resolutionOrder": [
    { "$ref": "#/sets/core" },
    { "$ref": "#/modifiers/color" },
    { "$ref": "#/modifiers/density" }
  ]
}
