{
  "name": "untheme",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zoobzio/untheme.git",
    "directory": "packages/untheme"
  },
  "type": "module",
  "main": "./.dist/index.mjs",
  "types": "./.dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./.dist/index.d.ts",
      "import": "./.dist/index.mjs"
    },
    "./catalog": {
      "types": "./.dist/catalog.d.ts",
      "import": "./.dist/catalog.mjs"
    },
    "./config": {
      "types": "./.dist/config.d.ts",
      "import": "./.dist/config.mjs"
    },
    "./css": {
      "types": "./.dist/css.d.ts",
      "import": "./.dist/css.mjs"
    },
    "./kit": {
      "types": "./.dist/kit.d.ts",
      "import": "./.dist/kit.mjs"
    }
  },
  "files": [
    ".dist"
  ],
  "scripts": {
    "build": "unbuild",
    "stub": "unbuild --stub",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@untheme/catalog": "workspace:*",
    "@untheme/core": "workspace:*",
    "@untheme/css": "workspace:*",
    "@untheme/kit": "workspace:*",
    "@untheme/schema": "workspace:*",
    "@untheme/utils": "workspace:*"
  }
}
