{
  "name": "@untheme/nuxt",
  "version": "0.0.0",
  "type": "module",
  "main": "./.dist/module.mjs",
  "types": "./.dist/module.d.ts",
  "exports": {
    ".": {
      "import": "./.dist/module.mjs",
      "types": "./.dist/module.d.ts"
    },
    "./config": {
      "import": "./.dist/config.mjs",
      "types": "./.dist.config.d.ts"
    }
  },
  "files": [
    ".dist"
  ],
  "scripts": {
    "build": "unbuild",
    "stub": "unbuild --stub",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --root ../.."
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.6",
    "h3": "2.0.1-rc.22",
    "untheme": "workspace:*",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@nuxt/schema": "^4.4.6",
    "@types/node": "^25.9.1",
    "nuxt": "^4.4.6"
  }
}
