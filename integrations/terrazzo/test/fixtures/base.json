{
  "color": {
    "$type": "color",
    "primary": {
      "50": {
        "$value": {
          "colorSpace": "srgb",
          "components": [0.9, 0.95, 1],
          "alpha": 1,
          "hex": "#e5f2ff"
        }
      },
      "600": {
        "$value": {
          "colorSpace": "srgb",
          "components": [
            0.11372549019607843, 0.3058823529411765, 0.8470588235294118
          ],
          "alpha": 1,
          "hex": "#1d4ed8"
        }
      },
      "default": { "$value": "{color.primary.600}" }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [1, 1, 1],
        "alpha": 1,
        "hex": "#ffffff"
      }
    }
  },
  "size": {
    "$type": "dimension",
    "sm": { "$value": { "value": 4, "unit": "px" } },
    "md": { "$value": { "value": 8, "unit": "px" } }
  },
  "time": {
    "$type": "duration",
    "fast": { "$value": { "value": 150, "unit": "ms" } }
  },
  "font": {
    "sans": { "$type": "fontFamily", "$value": ["Inter", "sans-serif"] },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 }
    }
  },
  "border": {
    "thin": {
      "$type": "border",
      "$description": "Hairline outline.",
      "$value": {
        "color": "{color.primary.600}",
        "width": "{size.sm}",
        "style": "solid"
      }
    }
  },
  "type": {
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{font.sans}",
        "fontSize": { "value": 1, "unit": "rem" },
        "fontWeight": 400,
        "letterSpacing": { "value": 0, "unit": "px" },
        "lineHeight": 1.5
      }
    }
  }
}
