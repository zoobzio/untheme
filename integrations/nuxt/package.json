{
  "name": "@untheme/nuxt",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zoobzio/untheme.git",
    "directory": "integrations/nuxt"
  },
  "type": "module",
  "main": "./.dist/module.mjs",
  "types": "./.dist/module.d.ts",
  "exports": {
    ".": {
      "types": "./.dist/module.d.ts",
      "import": "./.dist/module.mjs"
    },
    "./config": {
      "types": "./.dist/config.d.ts",
      "import": "./.dist/config.mjs"
    },
    "./constant": {
      "types": "./.dist/constant.d.ts",
      "import": "./.dist/constant.mjs"
    }
  },
  "files": [
    ".dist"
  ],
  "scripts": {
    "build": "unbuild",
    "stub": "unbuild --stub",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.6",
    "h3": "^1.15.11",
    "objectively": "^0.1.1",
    "untheme": "workspace:*",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@nuxt/nitro-server": "^4.4.6",
    "@nuxt/schema": "^4.4.6",
    "@types/node": "^25.9.1",
    "nitropack": "^2.13.4",
    "nuxt": "^4.4.6"
  }
}
